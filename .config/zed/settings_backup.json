{
  "context_servers": {
    "mcp-server-context7": {
      "source": "extension",
      "enabled": true,
      "settings": {
        "context7_api_key": "ctx7sk-9f5916e9-8710-4b8b-a9fa-fec737611b7d"
      }
    }
  },
  "agent": {
    "always_allow_tool_actions": true,
    "model_parameters": []
  },
  "features": {
    "edit_prediction_provider": "supermaven"
  },
  "show_edit_predictions": true,
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "soft_wrap": "editor_width",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Oxocarbon Dark (Variant I)"
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace"
          // "typeCheckingMode": "strict"
        },
        "python": {
          "pythonPath": ".venv/bin/python"
        }
      }
    },
    "wakatime": {
      "settings": {
        "api-key": ""
      }
    }
  },
  "languages": {
    "Go": {
      "show_edit_predictions": true
    },
    "Python": {
      "language_servers": ["ruff", "pyright"],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "buffer_font_family": "FiraCode Nerd Font",
  "ui_font_family": "FiraCode Nerd Font",
  "relative_line_numbers": true,
  "cursor_blink": false,
  "scrollbar": {
    "show": "never"
  },
  "buffer_line_height": {
    "custom": 1.75
  }
}
